# Postgres connection string (Railway: a reference variable to the Postgres plugin).
DATABASE_URL=postgresql://localhost:5432/ghostr

# Max number of company feeds fetched concurrently.
POLL_CONCURRENCY=4

# Per-request abort timeout, in milliseconds.
REQUEST_TIMEOUT_MS=10000

# Descriptive User-Agent sent with every ATS request.
USER_AGENT=ghostr (+https://ghostr.dev)

# How many days after a listing closes it can still anchor a repost into the same job.
REPOST_WINDOW_DAYS=30
