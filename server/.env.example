# Port the API listens on.
PORT=3001

# Postgres connection string (shared with the cron). On Railway, set this to a
# reference variable pointing at the Postgres plugin.
DATABASE_URL=postgresql://localhost:5432/ghostr

# CORS allowlist: comma-separated origins, or `*` to allow any.
ALLOWED_ORIGINS=*

# Per-IP hourly cap on read endpoints (the whole /api surface is read-only).
READ_RATE_LIMIT_PER_HOUR=600
